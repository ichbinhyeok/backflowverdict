JAVA_OPTS=-Xms256m -Xmx768m
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
APP_SITE_BASE_URL=https://example.com
APP_DATA_ROOT=/opt/backflowverdict/data
APP_LEADS_ROOT=/opt/backflowverdict/leads
APP_ADMIN_USERNAME=
APP_ADMIN_PASSWORD=
APP_OPS_FRESHNESS_REPORT_PATH=/opt/backflowverdict/ops/freshness_report.json
APP_OPS_VERIFICATION_REPORT_PATH=/opt/backflowverdict/ops/verification_report.json
APP_OPS_ALLOW_LOCAL_REQUESTS=false
APP_OPS_VERIFICATION_TOKEN=replace-with-a-long-random-token
GG_JTE_DEVELOPMENT_MODE=false
GG_JTE_USE_PRECOMPILED_TEMPLATES=true
